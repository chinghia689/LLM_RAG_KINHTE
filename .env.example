# ============================================================
# CẤU HÌNH HỆ THỐNG (FastAPI)
# ============================================================
ENV=development
# Các giá trị: development (DEBUG log) hoặc production (INFO log)

# ============================================================
# CẤU HÌNH AI ENGINE
# ============================================================
# LLM Provider mặc định khi khởi động server
DEFAULT_LLM=openai

# OpenAI
KEY_API_OPENAI=
OPENAI_LLM_MODEL_NAME=gpt-4o-mini

# Google Gemini
GOOGLE_API_KEY=
GOOGLE_LLM_MODEL_NAME=gemini-2.5-flash

# Groq
GROQ_API_KEY=

# ============================================================
# GOOGLE OAUTH 2.0 (Đăng nhập)
# ============================================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# JWT Secret Key
# ============================================================
JWT_SECRET_KEY=thay-doi-key-nay-khi-deploy-production

# ============================================================
# OAuth Redirect URI (thay đổi theo domain deploy)
# ============================================================
OAUTH_REDIRECT_URI=http://localhost:8001/api/v1/auth/google/callback/flutter
